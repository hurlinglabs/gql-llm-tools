{
  "name": "gql-schema-scout",
  "version": "0.0.10",
  "license": "Apache-2.0",
  "type": "module",
  "description": "Alias for @hurling/gql-schema-scout - WARNING: This is an alias package. Please use @hurling/gql-schema-scout for new projects. CLI users should install @hurling/gql-schema-scout directly.",
  "repository": "github:hurlinglabs/gql-llm-tools",
  "keywords": [
    "graphql",
    "llm",
    "ai",
    "agent",
    "schema",
    "mcp",
    "model-context-protocol",
    "gpt",
    "chatgpt",
    "openai",
    "anthropic",
    "context-window",
    "schema-exploration"
  ],
  "homepage": "https://github.com/hurlinglabs/gql-llm-tools/tree/main/packages/libaries/gql-schema-scout",
  "bugs": "https://github.com/hurlinglabs/gql-llm-tools/issues",
  "files": [
    "dist",
    "preinstall-alert.txt"
  ],
  "bin": {
    "gql-schema-scout": "./dist/es/cli.js"
  },
  "main": "./dist/es/index.js",
  "module": "./dist/es/index.js",
  "types": "./dist/es/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/es/index.d.ts",
        "default": "./dist/es/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./cli": {
      "import": {
        "types": "./dist/es/cli.d.ts",
        "default": "./dist/es/cli.js"
      },
      "require": {
        "types": "./dist/cjs/cli.d.cts",
        "default": "./dist/cjs/cli.cjs"
      }
    }
  },
  "scripts": {
    "preinstall": "echo -e \"$(cat ./preinstall-alert.txt)\"",
    "build": "bunchee",
    "dev": "bunchee --watch",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "@hurling/gql-schema-scout": "workspace:*"
  },
  "dependencies": {
    "@hurling/gql-schema-scout": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@hurling/gql-llm-tools-config-tsconfig": "workspace:*",
    "@hurling/gql-llm-tools-config-eslint": "workspace:*",
    "@types/node": "^22.15.3",
    "bunchee": "^6.4.0",
    "eslint": "^9.39.0",
    "typescript": "5.9.3"
  }
}
